@inject PortfolioContentService Content

<footer id="contact" class="site-footer">
    <div class="shell footer-content">
        <div class="section-heading footer-heading">
            <p class="eyebrow">Connect</p>
            <h2>Let's discuss reliable systems and operations.</h2>
        </div>
    @if (property is null)
    {
        <p><em>Loading contact options...</em></p>
    }
    else if (icons is not null)
    {
        <nav class="contact-links" aria-label="Professional contact links">
            @if (string.IsNullOrWhiteSpace(property.Email) is false)
            {
                <a href="mailto:@(property.Email)" class="contact-link">
                    <img src="@icons.Email" alt="" aria-hidden="true" class="social-icon" />
                    <span>Email</span>
                </a>
            }
            @if (string.IsNullOrWhiteSpace(property.GitHub) is false)
            {
                <a href="https://github.com/@(property.GitHub)" target="_blank" rel="noopener noreferrer" class="contact-link">
                    <img src="@icons.GitHub" alt="" aria-hidden="true" class="social-icon" />
                    <span>GitHub</span>
                </a>
            }
            @if (string.IsNullOrWhiteSpace(property.LinkedIn) is false)
            {
                <a href="https://linkedin.com/in/@(property.LinkedIn)" target="_blank" rel="noopener noreferrer" class="contact-link">
                    <img src="@icons.LinkedIn" alt="" aria-hidden="true" class="social-icon" />
                    <span>LinkedIn</span>
                </a>
            }
        </nav>
        <p class="footer-note">Designed and built by @property.Name using Blazor WebAssembly.</p>
    }
    </div>
</footer>

@code {
    private SiteProperties? property;
    private SocialIcons? icons;

    protected override async Task OnInitializedAsync()
    {
        property = await Content.GetSitePropertiesAsync();
        icons = await Content.GetSocialIconsAsync();
    }
}
