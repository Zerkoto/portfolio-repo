@inject PortfolioContentService Content

<section class="section about" id="about" aria-labelledby="about-heading">
    <header class="section-heading">
        <p class="section-kicker">About</p>
        <h2 id="about-heading">A high-achievement profile built across sectors</h2>
    </header>
    @if (aboutMe is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <p class="section-intro">@aboutMe.Introduction</p>
        <p class="about-detail">@aboutMe.Evidence</p>
        <div class="achievement-strip" aria-label="Selected achievements">
            @foreach (var highlight in aboutMe.Highlights)
            {
                <span>
                    <IconMark Name="education" />
                    @highlight
                </span>
            }
        </div>
        <div class="focus-grid">
            @foreach (var focusArea in aboutMe.FocusAreas)
            {
                <article class="card focus-card">
                    <div class="card-topline">
                        <span class="icon-badge">
                            <IconMark Name="@focusArea.Icon" />
                        </span>
                        <p class="card-label">@focusArea.Tagline</p>
                    </div>
                    <h3>@focusArea.Title</h3>
                    <p>@focusArea.Description</p>
                    <ul class="compact-list">
                        @foreach (var bullet in focusArea.Bullets)
                        {
                            <li>@bullet</li>
                        }
                    </ul>
                </article>
            }
        </div>
    }
</section>

@code {
    private AboutMe? aboutMe;

    protected override async Task OnInitializedAsync()
    {
        aboutMe = await Content.GetAboutMeAsync();
    }
}
